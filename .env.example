# =============================================================================
# Wishify — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# BACKEND (Railway)
# =============================================================================

# PostgreSQL connection string (Railway auto-provides DATABASE_URL)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wishify

# Redis connection string (Railway auto-provides REDIS_URL)
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=changeme-replace-with-64-random-chars-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (get from https://console.cloud.google.com/)
# Authorized redirect URI (local): http://localhost:8000/api/v1/auth/google/callback
# Authorized redirect URI (prod):  https://<your-railway-url>/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL — used for OAuth redirects after login
# Local: http://localhost:3000
# Production: https://<your-vercel-url>
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins (no trailing slash, no wildcards in prod)
# Example: https://wishify.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# FRONTEND (Vercel)
# =============================================================================

# Full base URL of the backend API (no trailing slash)
# Local: http://localhost:8000/api/v1
# Production: https://<your-railway-url>/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket base URL (ws:// or wss:// scheme, no /ws suffix — added by the hook)
# Local: ws://localhost:8000/api/v1
# Production: wss://<your-railway-url>/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1

# Google OAuth client ID (same value as backend GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
